# Copy this file to .env.production on the server. Never commit real secrets.
DEEPSEEK_API_KEY=replace_with_your_deepseek_api_key

# The first startup creates this bootstrap administrator when it does not exist.
APP_USERNAME=replace_with_admin_username
APP_PASSWORD=replace_with_a_strong_admin_password

# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=replace_with_a_long_random_value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# The compose file overrides the database and upload paths with persistent volumes.
DATABASE_URL=sqlite:////app/data/app.db
UPLOAD_STORAGE_DIR=/app/data/uploads

# Use your final public URL. Multiple origins are separated by commas.
CORS_ORIGINS=http://your-server-public-ip,https://your-domain.example
